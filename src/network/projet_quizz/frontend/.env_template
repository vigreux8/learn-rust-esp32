# Copier vers `.env` : cp .env_template .env
# Variables lues par `vite.config.ts` (proxy /api → Nest en dev et preview).

# URL du backend Nest (proxy Vite). En local, laisser la valeur par défaut.
# Avec ngrok : un seul tunnel sur le front (5174) ; ne pas pointer vers l’URL ngrok du back.
QUIZZ_API_PROXY_TARGET=http://127.0.0.1:3001

# Optionnel — build / prod : base API complète (sinon chemins relatifs /api).
# VITE_API_URL=https://exemple.example.com

# Optionnel — version affichée dans l’UI.
# VITE_APP_VERSION=0.0.0
